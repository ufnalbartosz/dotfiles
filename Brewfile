# Brewfile — install with: brew bundle
# Run automatically by setup.sh

# Core dev tools
brew "git"
brew "gh"          # GitHub CLI — used for auth and MCP
brew "node"        # Required for npx (MCP servers, Claude Code)
brew "uv"          # Required for uvx (ruff, pytest MCP servers)

# Python tooling
brew "pyright"     # Python type checker (used by Claude Code LSP plugin)

# Security
brew "snyk"        # Security scanning MCP server

# Apps
cask "cursor"      # Cursor IDE
