// Place your key bindings in this file to override the defaults
[
    {
        "key": "cmd+i",
        "command": "composerMode.agent"
    },
    {
        "key": "shift+enter",
        "command": "workbench.action.terminal.sendSequence",
        "args": {
            "text": "\u001b\r"
        },
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+x m",
        "command": "workbench.action.toggleMaximizedPanel"
    },
    {
        "key": "alt+cmd+s",
        "command": "workbench.action.toggleUnifiedSidebarFromKeyboard",
        "when": "cursor.agentIdeUnification.enabled == true && !isAuxiliaryWindowFocusedContext"
    },
    // Terminal management (ctrl+x chords, terminal-scoped)
    {
        "key": "ctrl+x ctrl+c",
        "command": "workbench.action.terminal.new",
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+x ctrl+k",
        "command": "workbench.action.terminal.kill",
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+x up",
        "command": "workbench.action.terminal.focusPrevious",
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+x down",
        "command": "workbench.action.terminal.focusNext",
        "when": "terminalFocus"
    },
    // Toggle focus between editor and terminal
    {
        "key": "cmd+\\",
        "command": "workbench.action.terminal.focus",
        "when": "editorTextFocus"
    },
    {
        "key": "cmd+\\",
        "command": "workbench.action.focusActiveEditorGroup",
        "when": "terminalFocus"
    },
    {
        "key": "cmd+\\",
        "command": "-workbench.action.terminal.split",
        "when": "terminalFocus"
    },
    {
        "key": "cmd+\\",
        "command": "workbench.action.focusActiveEditorGroup",
        "when": "explorerViewletFocus"
    },
    {
        "key": "ctrl+x ctrl+z",
        "command": "workbench.action.toggleZenMode"
    },
    {
        "key": "ctrl+x ctrl+g",
        "command": "gitlens.showGraphView"
    },
    {
        "key": "ctrl+x ctrl+e",
        "command": "workbench.view.explorer"
    },
    {
        "key": "ctrl+x ctrl+t",
        "command": "workbench.action.terminal.toggleTerminal"
    },
    {
        "key": "ctrl+x ctrl+s",
        "command": "workbench.action.files.save",
        "when": "editorTextFocus"
    },
    {
        "key": "ctrl+x s",
        "command": "workbench.action.findInFiles"
    },
    {
        "key": "ctrl+x o",
        "command": "workbench.action.focusFirstEditorGroup",
        "when": "terminalFocus"
    },
    {
        "key": "ctrl+x o",
        "command": "workbench.action.focusSecondEditorGroup",
        "when": "editorTextFocus && activeEditorGroupIndex == 1 && multipleEditorGroups"
    },
    {
        "key": "ctrl+x o",
        "command": "workbench.action.terminal.focus",
        "when": "editorTextFocus && activeEditorGroupIndex == 2"
    },
    {
        "key": "ctrl+x o",
        "command": "workbench.action.terminal.focus",
        "when": "editorTextFocus && !multipleEditorGroups"
    },
    {
        "key": "ctrl+x o",
        "command": "workbench.action.focusActiveEditorGroup",
        "when": "explorerViewletFocus"
    },
    {
        "key": "ctrl+x ctrl+i",
        "command": "editor.action.indentLines",
        "when": "editorTextFocus && !editorReadonly"
    },
    // Move lines up/down
    {
        "key": "alt+shift+p",
        "command": "editor.action.moveLinesUpAction",
        "when": "editorTextFocus && !editorReadonly"
    },
    {
        "key": "alt+shift+n",
        "command": "editor.action.moveLinesDownAction",
        "when": "editorTextFocus && !editorReadonly"
    },
    // --- New bindings below ---
    {
        "key": "ctrl+x ctrl+p",
        "command": "test-navigator.jumpTest",
        "when": "editorTextFocus"
    },
    {
        "key": "cmd+.",
        "command": "editor.action.revealDefinition",
        "when": "editorHasDefinitionProvider && editorTextFocus"
    },
    {
        "key": "ctrl+x ctrl+shift+p",
        "command": "test-navigator.createTest",
        "when": "editorTextFocus"
    },
    {
        "key": "cmd+,",
        "command": "-workbench.action.openSettings"
    },
    {
        "key": "cmd+,",
        "command": "workbench.action.navigateBack"
    },
    {
        "key": "cmd+/",
        "command": "editor.action.commentLine",
        "when": "editorTextFocus && !editorReadonly"
    },
    {
        "key": "ctrl+m",
        "command": "-editor.action.toggleTabFocusMode"
    },
    {
        "key": "cmd+j",
        "command": "workbench.action.togglePanel"
    },
    {
        "key": "cmd+j",
        "command": "-workbench.action.chat.toggleAgentMode"
    },
    {
        "key": "escape",
        "command": "workbench.action.chat.stopInChatSession",
        "when": "inChat"
    }
]
