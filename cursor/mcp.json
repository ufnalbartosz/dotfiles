{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "<add-your-token>"
      }
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "cclsp-python": {
      "command": "npx",
      "args": ["-y", "cclsp", "--language", "python", "--command", "pyright-langserver", "--args", "--stdio"]
    },
    "cclsp-typescript": {
      "command": "npx",
      "args": ["-y", "cclsp", "--language", "typescript", "--command", "typescript-language-server", "--args", "--stdio"]
    }
  }
}
